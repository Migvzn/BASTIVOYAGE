# =====================================================
#  BastiVoyage — Environment Variables
#  Copy this file to `.env.local` (dev) or set them in Vercel Project Settings.
#  All keys are OPTIONAL — the app falls back to realistic mock data when missing.
# =====================================================

# --- CORE (required for real AI plans) ---
# Generate at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxx


# --- FLIGHTS ---
# Amadeus self-service: https://developers.amadeus.com/
# Free tier supports flight search + airport lookup.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# (Optional) Skyscanner partner affiliate id, appended to booking_links
SKYSCANNER_AFFILIATE_ID=


# --- HOTELS ---
# RapidAPI key with subscription to "Booking.com" community APIs.
# https://rapidapi.com/apidojo/api/booking/
RAPIDAPI_KEY=
RAPIDAPI_BOOKING_HOST=booking-com.p.rapidapi.com

# Booking.com Partner Hub affiliate id, appended to deeplinks
BOOKING_AFFILIATE_ID=


# --- REVIEWS / PLACES ---
# Google Cloud Console → enable "Places API"
# https://developers.google.com/maps/documentation/places/web-service
GOOGLE_PLACES_API_KEY=


# --- TRANSPORT (future use) ---
# Rome2Rio API (partners): https://www.rome2rio.com/documentation/
ROME2RIO_API_KEY=

# SNCF Connect: requires partner agreement, public deeplinks always work
SNCF_API_KEY=
