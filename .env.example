# =====================================================
#  BastiVoyage — Environment Variables
#  Copy this file to `.env.local` (dev) or set them in Vercel Project Settings.
#  All keys are OPTIONAL — the app falls back gracefully when missing.
# =====================================================

# --- CORE AI (required for real AI plans) ---
# Generate at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxx


# --- FLIGHTS ---
# Amadeus self-service: https://developers.amadeus.com/
# Free tier supports flight search + airport lookup.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# (Optional) Skyscanner partner affiliate id, appended to booking_links
SKYSCANNER_AFFILIATE_ID=


# --- HOTELS ---
# RapidAPI key with subscription to "Booking.com" community APIs.
# https://rapidapi.com/apidojo/api/booking/
RAPIDAPI_KEY=
RAPIDAPI_BOOKING_HOST=booking-com.p.rapidapi.com

# Booking.com Partner Hub affiliate id, appended to deeplinks
BOOKING_AFFILIATE_ID=


# --- REVIEWS / PLACES ---
# Google Cloud Console → enable "Places API"
# https://developers.google.com/maps/documentation/places/web-service
GOOGLE_PLACES_API_KEY=


# --- TRANSPORT (optional, deeplinks work without keys) ---
ROME2RIO_API_KEY=
SNCF_API_KEY=


# --- DATABASE & AUTH (Supabase) ---
# Create a project at https://supabase.com/dashboard
# Then run /supabase/schema.sql in the SQL editor
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Used server-side only — gives you bypass-RLS access (keep secret)
SUPABASE_SERVICE_ROLE_KEY=


# --- PAYMENTS (Stripe) ---
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxx

# Create a one-time product in Stripe Dashboard → Products
# Copy the price ID (price_xxx)
STRIPE_PREMIUM_PRICE_ID=price_xxxxxxxxxxxxxx


# --- VERCEL CRON ---
# Generate a random string. Vercel Cron will send this as Bearer token.
# Required if you want the cron endpoint locked.
CRON_SECRET=
